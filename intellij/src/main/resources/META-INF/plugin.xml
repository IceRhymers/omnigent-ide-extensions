<!-- Omnigent IntelliJ/PyCharm plugin descriptor (B1).
     version is stamped from the build (pluginConfiguration.version = project
     version, default 0.1.0). sinceBuild=241 / open untilBuild come from the
     build's ideaVersion block (gradle.properties). -->
<idea-plugin>
    <id>ai.omnigent.intellij</id>
    <name>Omnigent</name>
    <version>0.1.0</version>
    <vendor email="support@omnigent.example" url="https://github.com/omnigent-ai/omnigent">Omnigent (vendor placeholder)</vendor>

    <description><![CDATA[
        Brings <b>Omnigent</b> into IntelliJ IDEA and PyCharm. Embeds the Omnigent
        web UI in a JCEF tool window pointed at a configurable server target
        (auto-discovered local server or a manual remote/Databricks URL), plus
        native editor actions: send selection/file to the agent, open/switch a
        session with a connection-status indicator, and view/apply changed-file
        diffs in the native diff viewer.
    ]]></description>

    <!-- Target IDEA + PyCharm (Community + Professional). The platform module
         is the common base shared by all IDEs; the JCEF tool window + the three
         actions use only platform APIs so the single plugin loads in every
         listed IDE without an IDE-specific module dependency. -->
    <depends>com.intellij.modules.platform</depends>

    <extensions defaultExtensionNs="com.intellij">
        <!-- B2: JCEF tool window (live-navigate to the resolved server URL). -->
        <toolWindow
            id="Omnigent"
            anchor="right"
            secondary="false"
            icon="/icons/omnigent.svg"
            factoryClass="ai.omnigent.intellij.toolwindow.OmnigentToolWindowFactory"/>

        <!-- Phase 3: dedicated, LEFT-anchored Sessions list tool window (Option D).
             A SEPARATE window from the right-anchored Omnigent JCEF window so the
             list and the conversation stay concurrently visible. Distinct icon. -->
        <toolWindow
            id="OmnigentSessions"
            anchor="left"
            secondary="false"
            icon="/icons/omnigent-sessions.svg"
            factoryClass="ai.omnigent.intellij.sessions.SessionsToolWindowFactory"/>

        <!-- Persisted settings (server URL + optional token override). -->
        <applicationService
            serviceImplementation="ai.omnigent.intellij.config.OmnigentSettings"/>

        <!-- Phase 5: Settings → Tools → Omnigent (BoundConfigurable, APP-level). -->
        <applicationConfigurable
            parentId="tools"
            id="ai.omnigent.intellij.config.OmnigentConfigurable"
            instance="ai.omnigent.intellij.config.OmnigentConfigurable"
            displayName="Omnigent"/>

        <!-- Phase 5: the single canonical status surface (status-bar widget).
             Anchored after the editor read-only widget on the status bar. -->
        <statusBarWidgetFactory
            id="ai.omnigent.intellij.StatusBarWidget"
            implementation="ai.omnigent.intellij.statusbar.OmnigentStatusBarWidgetFactory"
            order="after readOnlyWidget"/>

        <!-- Notification group for the Sessions click-to-open no-op feedback. -->
        <notificationGroup id="Omnigent" displayType="BALLOON"/>
    </extensions>

    <actions>
        <!-- B4: three native actions. -->
        <action
            id="ai.omnigent.intellij.SendSelection"
            class="ai.omnigent.intellij.actions.SendSelectionAction"
            text="Omnigent: Send Selection to Agent"
            description="Send the current editor selection or file to the active Omnigent session.">
            <add-to-group group-id="EditorPopupMenu" anchor="last"/>
            <add-to-group group-id="ToolsMenu" anchor="last"/>
        </action>

        <action
            id="ai.omnigent.intellij.OpenSession"
            class="ai.omnigent.intellij.actions.OpenSessionAction"
            text="Omnigent: Open / Switch Session"
            description="Open/focus the Omnigent tool window and create or resume a session.">
            <add-to-group group-id="ToolsMenu" anchor="last"/>
            <!-- Phase 5 default keybindings: a free "O then S" chord under the
                 Omnigent mnemonic (Ctrl+Alt+O on $default, Meta+Alt+O on macOS). -->
            <keyboard-shortcut keymap="$default" first-keystroke="control alt O" second-keystroke="S"/>
            <keyboard-shortcut keymap="Mac OS X 10.5+" first-keystroke="meta alt O" second-keystroke="S"/>
        </action>

        <action
            id="ai.omnigent.intellij.ViewDiffs"
            class="ai.omnigent.intellij.actions.ViewDiffsAction"
            text="Omnigent: View Changed Files (Diffs)"
            description="View the session's changed files in the native diff viewer (view-only for all sessions).">
            <add-to-group group-id="ToolsMenu" anchor="last"/>
        </action>

        <action
            id="ai.omnigent.intellij.ApplyDiffs"
            class="ai.omnigent.intellij.actions.ApplyDiffsAction"
            text="Omnigent: Apply Changed Files"
            description="Apply the session's changed files to the workspace (local sessions only).">
            <add-to-group group-id="ToolsMenu" anchor="last"/>
        </action>

        <!-- Phase 3: Sessions tool-window toolbar actions. The toolbar group is
             built in code (SessionsPanel) from these registered actions. -->
        <action
            id="ai.omnigent.intellij.sessions.Refresh"
            class="ai.omnigent.intellij.sessions.actions.RefreshSessionsAction"
            text="Omnigent: Refresh Sessions"
            description="Reload the Omnigent session list.">
            <add-to-group group-id="ToolsMenu" anchor="last"/>
            <!-- "O then R" chord, sharing the Omnigent mnemonic prefix. -->
            <keyboard-shortcut keymap="$default" first-keystroke="control alt O" second-keystroke="R"/>
            <keyboard-shortcut keymap="Mac OS X 10.5+" first-keystroke="meta alt O" second-keystroke="R"/>
        </action>
        <action
            id="ai.omnigent.intellij.sessions.Filter"
            class="ai.omnigent.intellij.sessions.actions.FilterSessionsAction"
            text="Filter Sessions…"
            description="Filter sessions by agent, status, branch, title, or folder."/>
        <action
            id="ai.omnigent.intellij.sessions.ToggleArchived"
            class="ai.omnigent.intellij.sessions.actions.ToggleArchivedAction"
            text="Toggle Archived Sessions"
            description="Show or hide archived sessions."/>
        <action
            id="ai.omnigent.intellij.sessions.ClearFilters"
            class="ai.omnigent.intellij.sessions.actions.ClearFiltersAction"
            text="Clear Session Filters"
            description="Reset all session filters to the default."/>

        <group id="ai.omnigent.intellij.sessions.Toolbar">
            <reference ref="ai.omnigent.intellij.sessions.Refresh"/>
            <reference ref="ai.omnigent.intellij.sessions.Filter"/>
            <reference ref="ai.omnigent.intellij.sessions.ToggleArchived"/>
            <reference ref="ai.omnigent.intellij.sessions.ClearFilters"/>
        </group>
    </actions>
</idea-plugin>
