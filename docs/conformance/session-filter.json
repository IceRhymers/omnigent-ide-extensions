{
  "description": "Language-neutral conformance vectors for the PORTABLE Sessions-picker contracts shared by the VS Code (vscode/src/sessions/filter.ts + treeItem.ts) and IntelliJ (intellij/.../sessions/) implementations. Each case has an 'fn' selecting the function under test. Deliberately EXCLUDED (platform-conditional / deliberately divergent, tested language-locally): normalizeWorkspacePath path-CASING and statusIcon/themeIcon mapping. The case-sensitive workspace-equality branch of matchesFilter is exercised here with ALREADY-NORMALIZED, all-lowercase inputs so the expected result is correct on every platform. Sessions use the wire JSON field names (agent_name, git_branch, updated_at, status, workspace, title, archived); the SessionFilter object uses workspacePath/gitBranch/agentName/status/titleQuery/hideArchived/currentFolderOnly. relativeTime cases pass unixSecs + nowMs (ms) directly.",
  "cases": [
    {
      "name": "matchesFilter/hideArchived_drops_literal_true",
      "fn": "matchesFilter",
      "input": {
        "session": { "id": "conv_1", "archived": true },
        "filter": { "hideArchived": true, "currentFolderOnly": false }
      },
      "expected": { "matches": false }
    },
    {
      "name": "matchesFilter/hideArchived_keeps_false",
      "fn": "matchesFilter",
      "input": {
        "session": { "id": "conv_1", "archived": false },
        "filter": { "hideArchived": true, "currentFolderOnly": false }
      },
      "expected": { "matches": true }
    },
    {
      "name": "matchesFilter/hideArchived_keeps_absent",
      "fn": "matchesFilter",
      "input": {
        "session": { "id": "conv_1" },
        "filter": { "hideArchived": true, "currentFolderOnly": false }
      },
      "expected": { "matches": true }
    },
    {
      "name": "matchesFilter/archived_true_kept_when_hideArchived_off",
      "fn": "matchesFilter",
      "input": {
        "session": { "id": "conv_1", "archived": true },
        "filter": { "hideArchived": false, "currentFolderOnly": false }
      },
      "expected": { "matches": true }
    },
    {
      "name": "matchesFilter/workspace_active_currentFolderOnly_but_path_null_excludes",
      "fn": "matchesFilter",
      "input": {
        "session": { "id": "conv_1", "workspace": "/repo/app" },
        "filter": { "hideArchived": false, "currentFolderOnly": true }
      },
      "expected": { "matches": false }
    },
    {
      "name": "matchesFilter/workspace_active_session_workspace_null_excludes",
      "fn": "matchesFilter",
      "input": {
        "session": { "id": "conv_1" },
        "filter": { "hideArchived": false, "currentFolderOnly": false, "workspacePath": "/repo/app" }
      },
      "expected": { "matches": false }
    },
    {
      "name": "matchesFilter/workspace_normalized_equality_match",
      "fn": "matchesFilter",
      "input": {
        "session": { "id": "conv_1", "workspace": "/repo/app" },
        "filter": { "hideArchived": false, "currentFolderOnly": false, "workspacePath": "/repo/app/" }
      },
      "expected": { "matches": true }
    },
    {
      "name": "matchesFilter/workspace_normalized_equality_mismatch",
      "fn": "matchesFilter",
      "input": {
        "session": { "id": "conv_1", "workspace": "/repo/app" },
        "filter": { "hideArchived": false, "currentFolderOnly": false, "workspacePath": "/repo/other" }
      },
      "expected": { "matches": false }
    },
    {
      "name": "matchesFilter/gitBranch_strict_equality_match",
      "fn": "matchesFilter",
      "input": {
        "session": { "id": "conv_1", "git_branch": "main" },
        "filter": { "hideArchived": false, "currentFolderOnly": false, "gitBranch": "main" }
      },
      "expected": { "matches": true }
    },
    {
      "name": "matchesFilter/gitBranch_case_sensitive_mismatch",
      "fn": "matchesFilter",
      "input": {
        "session": { "id": "conv_1", "git_branch": "Main" },
        "filter": { "hideArchived": false, "currentFolderOnly": false, "gitBranch": "main" }
      },
      "expected": { "matches": false }
    },
    {
      "name": "matchesFilter/gitBranch_set_vs_absent_session_field_mismatch",
