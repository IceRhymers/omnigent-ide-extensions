    {
      "name": "matchesFilter/AND_one_mismatch_fails_whole_filter",
      "fn": "matchesFilter",
      "input": {
        "session": { "id": "conv_1", "agent_name": "coder", "status": "idle", "title": "Deploy step" },
        "filter": { "hideArchived": true, "currentFolderOnly": false, "agentName": "coder", "status": "running", "titleQuery": "deploy" }
      },
      "expected": { "matches": false }
    },
    {
      "name": "isFilterActive/default_is_inactive",
      "fn": "isFilterActive",
      "input": { "filter": { "hideArchived": true, "currentFolderOnly": false } },
      "expected": { "active": false }
    },
    {
      "name": "isFilterActive/hideArchived_off_is_active",
      "fn": "isFilterActive",
      "input": { "filter": { "hideArchived": false, "currentFolderOnly": false } },
      "expected": { "active": true }
