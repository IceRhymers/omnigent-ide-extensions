      "fn": "matchesFilter",
      "input": {
        "session": { "id": "conv_1", "agent_name": "coder", "status": "running", "title": "Deploy step" },
        "filter": { "hideArchived": true, "currentFolderOnly": false, "agentName": "coder", "status": "running", "titleQuery": "deploy" }
      },
      "expected": { "matches": true }
