    {
      "name": "sortSessions/desc_by_updated_at_with_id_tiebreak",
      "fn": "sortSessions",
      "input": {
        "sessions": [
          { "id": "b", "updated_at": 100 },
          { "id": "a", "updated_at": 200 },
          { "id": "c", "updated_at": 100 }
        ]
      },
      "expected": { "order": ["a", "b", "c"] }
    },
    {
      "name": "sortSessions/missing_updated_at_treated_as_zero_sorts_last",
      "fn": "sortSessions",
      "input": {
        "sessions": [
          { "id": "x" },
          { "id": "y", "updated_at": 5 }
        ]
      },
      "expected": { "order": ["y", "x"] }
    },
    {
      "name": "sortSessions/id_tiebreak_lexicographic",
      "fn": "sortSessions",
      "input": {
        "sessions": [
          { "id": "conv_z", "updated_at": 10 },
          { "id": "conv_a", "updated_at": 10 },
          { "id": "conv_m", "updated_at": 10 }
        ]
      },
      "expected": { "order": ["conv_a", "conv_m", "conv_z"] }
    },
    {
      "name": "computeSignature/fetched_order_with_state",
      "fn": "computeSignature",
      "input": {
        "state": "ready",
        "sessions": [
          { "id": "b", "updated_at": 200, "status": "running" },
          { "id": "a", "updated_at": 100, "status": "idle" }
        ]
      },
      "expected": { "signature": "ready|b:200:running,a:100:idle" }
    },
    {
      "name": "computeSignature/absent_updated_at_and_status_render_empty",
      "fn": "computeSignature",
      "input": {
        "state": "ready",
        "sessions": [
          { "id": "a" },
          { "id": "b", "updated_at": 50 }
        ]
      },
      "expected": { "signature": "ready|a::,b:50:" }
    },
    {
      "name": "computeSignature/empty_list",
      "fn": "computeSignature",
      "input": { "state": "loading", "sessions": [] },
      "expected": { "signature": "loading|" }
    },
    {
